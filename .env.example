# Resend API Key for Feedback Email Delivery
RESEND_API_KEY=your_resend_api_key_here
RESEND_SUPPORT_API_KEY=your_resend_support_api_key_here

# Supabase Server SDK Configuration
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here
SUPABASE_SECRET_KEY=your_supabase_secret_key_here
SUPABASE_JWKS_URL=your_supabase_jwks_url_here

# Razorpay Payment Gateway Credentials (Test/Live Mode)
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here
RAZORPAY_PLAN_ID=your_razorpay_plan_id_here
RAZORPAY_LIFETIME_AMOUNT=199900
RAZORPAY_CURRENCY=INR

# Supabase PostgreSQL Database Connection details
# Host: db.yourproject.supabase.co
# Port: 5432
# Database: postgres
# User: postgres
DATABASE_URL="postgresql://postgres.yourproject:yourpassword@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres"
DATABASE_URL_ENCODED="postgresql://postgres.yourproject:yourpassword_encoded@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres"

# Admin Panel Configurations
ADMIN_EMAIL=your_admin_email_here
ADMIN_PASSWORD_HASH=your_bcrypt_password_hash_here
ADMIN_JWT_SECRET=your_strong_jwt_secret_key_here
